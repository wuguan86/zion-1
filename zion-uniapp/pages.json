{
	"easycom": {
		"autoscan": true,
		"custom": {
			"^u-(.*)": "uview-plus/components/u-$1/u-$1.vue"
		}
	},
	"pages": [
		{
			"path": "pages/index/index",
			"style": {
				"navigationBarTitleText": "消息"
			}
		},
		{
			"path": "pages/login/index",
			"style": {
				"navigationBarTitleText": "登录",
				"navigationStyle": "custom"
			}
		},
		{
			"path": "pages/chat/index",
			"style": {
				"navigationBarTitleText": "聊天",
				"enablePullDownRefresh": false
			}
		},
		{
			"path": "pages/contacts/index",
			"style": {
				"navigationBarTitleText": "通讯录"
			}
		},
		{
			"path": "pages/group-chat/index",
			"style": {
				"navigationBarTitleText": "群聊",
				"enablePullDownRefresh": false
			}
		},
		{
			"path": "pages/group/create",
			"style": {
				"navigationBarTitleText": "创建群聊"
			}
		},
		{
			"path": "pages/group/detail",
			"style": {
				"navigationBarTitleText": "群设置"
			}
		},
		{
			"path": "pages/profile/index",
			"style": {
				"navigationStyle": "custom",
				"navigationBarTextStyle": "white"
			}
		},
		{
			"path": "pages/profile/edit",
			"style": {
				"navigationBarTitleText": "个人信息"
			}
		},
		{
			"path": "pages/profile/password",
			"style": {
				"navigationBarTitleText": "修改密码"
			}
		}
	],
	"globalStyle": {
		"navigationBarTextStyle": "white",
		"navigationBarTitleText": "Zion 公共",
		"navigationBarBackgroundColor": "#07C160",
		"backgroundColor": "#EDEDED",
		"backgroundTextStyle": "dark"
	},
	"tabBar": {
		"color": "#999999",
		"selectedColor": "#07C160",
		"backgroundColor": "#ffffff",
		"borderStyle": "white",
		"list": [
			{
				"pagePath": "pages/index/index",
				"text": "消息",
				"iconPath": "static/tabbar/chat.png",
				"selectedIconPath": "static/tabbar/chat-active.png"
			},
			{
				"pagePath": "pages/contacts/index",
				"text": "通讯录",
				"iconPath": "static/tabbar/contacts.png",
				"selectedIconPath": "static/tabbar/contacts-active.png"
			},
			{
				"pagePath": "pages/profile/index",
				"text": "我的",
				"iconPath": "static/tabbar/profile.png",
				"selectedIconPath": "static/tabbar/profile-active.png"
			}
		]
	},
	"uniIdRouter": {}
}
